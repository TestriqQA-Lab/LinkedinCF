# LinkedIn OAuth (get from https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret

# NextAuth
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Google AI (get from https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Database (PostgreSQL — get from Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Vercel Blob (get from Vercel Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token

# Resend (email sending — get from https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=newsletter@yourdomain.com

# Razorpay (get from https://dashboard.razorpay.com/app/keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_ID_INR=plan_your_inr_plan
RAZORPAY_PLAN_ID_USD=plan_your_usd_plan

# Scheduler protection (Vercel sets CRON_SECRET automatically for cron jobs)
CRON_SECRET=generate_a_random_secret_here

# Site password protection (set to enable, remove to disable)
SITE_PASSWORD=your_site_password
