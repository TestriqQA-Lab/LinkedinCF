generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String        @id @default(cuid())
  linkedinId          String?       @unique
  name                String?
  email               String?       @unique
  emailVerified       DateTime?
  role                String        @default("user")  // "user" | "admin"
  image               String?
  headline            String?
  summary             String?
  skills              String?       // JSON array string
  industry            String?
  profileUrl          String?
  tonePrefs           String?       // JSON: formal/casual/inspirational
  // Onboarding & content preferences
  onboardingCompleted Boolean       @default(false)
  contentGoals        String?       // JSON: ["Lead Generation", "Brand Awareness"]
  positioning         String?       // "Thought Leader" | "Industry Expert" | etc.
  contentStyles       String?       // JSON: ["Narrative", "How-to", ...]
  targetAudience      String?       // free text description
  humanMode           Boolean       @default(false)
  postingSchedule     String?       // JSON: { days: ["Monday","Wednesday"], time: "09:00" }
  postSignature       String?       // Text always appended to every LinkedIn post
  timezone            String        @default("Asia/Kolkata") // IANA timezone string
  accounts            Account[]
  sessions            Session[]
  contentPlans        ContentPlan[]
  newsletters         Newsletter[]
  subscription        Subscription?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Subscription {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  razorpayCustomerId      String?   @unique
  razorpaySubscriptionId  String?   @unique
  razorpayPlanId          String?
  currency                String    @default("INR") // "INR" or "USD"
  status                  String    @default("trialing") // trialing|active|past_due|canceled|unpaid
  trialEnd                DateTime?
  currentPeriodEnd        DateTime?
  postsGeneratedThisCycle Int       @default(0)   // hard count of posts generated in current billing cycle
  cyclePostsResetAt       DateTime? // when the post counter was last reset (start of cycle)
  trialRemindersSent      String    @default("")  // comma-separated: "3d,1d,0d"
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model ContentPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime // Monday of the week this plan covers
  strategy  String   // JSON: pillars, theme, audience, tone, postMix
  posts     Post[]
  createdAt DateTime @default(now())

  @@unique([userId, weekStart])
}

model Post {
  id                String      @id @default(cuid())
  planId            String
  plan              ContentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title             String
  body              String
  imageUrl          String?
  imagePrompt       String?
  imageGenCount     Int         @default(0) // number of times image was generated for this post
  hashtags          String?     // JSON array string
  postType          String      // thought-leadership | tips | story | poll | carousel
  scheduledAt       DateTime?
  status            String      @default("draft") // draft | ready | published
  weekNumber        Int         @default(1)
  humanModeOverride Boolean?    // null = use user default, true = on, false = off
  postedToLinkedIn  Boolean     @default(false)
  linkedinPostId    String?     // UGC post ID from LinkedIn API
  postError         String?     // last error if auto-post failed
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Engagement metrics (future: populated via LinkedIn API with r_member_social scope)
  linkedinLikes       Int?
  linkedinComments    Int?
  linkedinShares      Int?
  linkedinImpressions Int?
  engagementSyncedAt  DateTime?

  @@index([planId])
  @@index([status])
  @@index([scheduledAt])
}

model Newsletter {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  subject     String
  body        String   // JSON: sections array
  pillars     String?  // JSON: source pillars used
  scheduledAt DateTime?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([scheduledAt])
}
